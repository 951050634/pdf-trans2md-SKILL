{
  "skill_name": "pdf-trans2md",
  "version": "3.0",
  "evals": [
    {
      "id": 1,
      "eval_name": "default-vision-first",
      "prompt": "请使用 pdf-trans2md 将 test-materials/double_column_journal_fixture.pdf 翻译为中文 Markdown。用户没有要求文本提取。",
      "expected_output": "采用页面渲染和当前 AI 模型的多模态视觉能力，不调用 Python PDF 文本提取。",
      "files": [
        {
          "path": "test-materials/double_column_journal_fixture.pdf",
          "purpose": "两页合成双栏期刊论文，包含跨栏摘要、图、公式、跨栏表格和脚注"
        }
      ],
      "assertions": [
        {
          "text": "默认选择视觉模式",
          "type": "behavior_contains",
          "pattern": "vision|多模态|页面图像|视觉"
        },
        {
          "text": "不得默认调用文本提取",
          "type": "behavior_not_contains",
          "pattern": "extract_text\\(|extract_pdf_text.py|--input-mode text"
        }
      ]
    },
    {
      "id": 2,
      "eval_name": "bilingual-original-before-translation",
      "prompt": "将 test-materials/double_column_journal_fixture.pdf 的第 1 页翻译为中英双语 Markdown，使用 bilingual 模式。",
      "expected_output": "每个语义块先输出英文原文，再用 Markdown 引用块输出中文译文。",
      "files": [
        {
          "path": "test-materials/double_column_journal_fixture.pdf",
          "purpose": "双语顺序测试"
        }
      ],
      "assertions": [
        {
          "text": "原文位于译文之前",
          "type": "ordered_content",
          "patterns": [
            "The left column begins the main argument",
            "> **译文：**"
          ]
        },
        {
          "text": "中文译文使用引用块",
          "type": "content_contains",
          "pattern": "^> \\*\\*译文(?:标题)?[：:]\\*\\*"
        },
        {
          "text": "禁止旧版原文引用块",
          "type": "content_not_contains",
          "pattern": "> \\*\\*原文.*English"
        }
      ]
    },
    {
      "id": 3,
      "eval_name": "double-column-reading-order",
      "prompt": "翻译 test-materials/double_column_journal_fixture.pdf，并重点保持期刊双栏的自然阅读顺序。",
      "expected_output": "先处理左栏的 Introduction/Method，再处理右栏的 Layout Analysis；不得左右栏逐行交叉。",
      "files": [
        {
          "path": "test-materials/double_column_journal_fixture.pdf",
          "purpose": "包含明确左栏和右栏顺序标记的双栏测试页"
        }
      ],
      "assertions": [
        {
          "text": "左栏内容先于右栏内容",
          "type": "ordered_content",
          "patterns": [
            "The workflow first identifies",
            "After the left column is complete"
          ]
        },
        {
          "text": "跨栏摘要在双栏正文前",
          "type": "ordered_content",
          "patterns": [
            "This synthetic article evaluates",
            "The left column begins"
          ]
        }
      ]
    },
    {
      "id": 4,
      "eval_name": "figures-equations-and-spanning-table",
      "prompt": "使用视觉模式翻译 test-materials/double_column_journal_fixture.pdf，保留图、公式和跨栏表格的语义位置。",
      "expected_output": "Figure 1 的图注不混入正文，公式编号保留，Table 1 位于两栏正文之后。",
      "files": [
        {
          "path": "test-materials/double_column_journal_fixture.pdf",
          "purpose": "图表和公式布局测试"
        }
      ],
      "assertions": [
        {
          "text": "图号和图注存在",
          "type": "content_contains",
          "pattern": "Figure 1|图 1"
        },
        {
          "text": "公式编号保留",
          "type": "content_contains",
          "pattern": "L\\(p\\).*\\(1\\)"
        },
        {
          "text": "跨栏表格存在",
          "type": "content_contains",
          "pattern": "TABLE 1|表 1"
        }
      ]
    },
    {
      "id": 5,
      "eval_name": "explicit-text-extraction",
      "prompt": "请不要识图。明确使用 pypdf 提取 test-materials/double_column_journal_fixture.pdf 第 1 页的文本，然后准备中文翻译。",
      "expected_output": "允许调用 scripts/extract_pdf_text.py，并显式传入 --input-mode text。",
      "files": [
        {
          "path": "test-materials/double_column_journal_fixture.pdf",
          "purpose": "显式文本模式测试"
        }
      ],
      "assertions": [
        {
          "text": "文本模式具有明确授权",
          "type": "behavior_contains",
          "pattern": "extract_pdf_text.py.*--input-mode text"
        },
        {
          "text": "提示文本层可能损坏双栏顺序",
          "type": "content_contains",
          "pattern": "双栏|column|布局|阅读顺序"
        }
      ]
    },
    {
      "id": 6,
      "eval_name": "scanned-pdf-no-text-layer",
      "prompt": "翻译一个没有文本层的扫描版双栏论文 PDF，并输出中文 Markdown。",
      "expected_output": "继续采用页面图像和多模态识别，不要求用户先使用 pypdf 或外部文字提取。",
      "files": [],
      "assertions": [
        {
          "text": "扫描 PDF 使用视觉路径",
          "type": "behavior_contains",
          "pattern": "渲染|页面图像|视觉|多模态"
        },
        {
          "text": "不因无文本层直接失败",
          "type": "behavior_not_contains",
          "pattern": "No text content extracted|必须先.*pypdf"
        }
      ]
    },
    {
      "id": 7,
      "eval_name": "page-range-and-rendering",
      "prompt": "使用默认模式翻译 test-materials/double_column_journal_fixture.pdf 的第 1-2 页，页面较密，请以 280 DPI 渲染。",
      "expected_output": "正确解析 1-2 页并使用视觉渲染脚本，DPI 为 280。",
      "files": [
        {
          "path": "test-materials/double_column_journal_fixture.pdf",
          "purpose": "页码和 DPI 测试"
        }
      ],
      "assertions": [
        {
          "text": "正确传递页码和 DPI",
          "type": "behavior_contains",
          "pattern": "render_pdf_pages.py.*--pages 1-2.*--dpi 280"
        }
      ]
    },
    {
      "id": 8,
      "eval_name": "uncertainty-no-hallucination",
      "prompt": "论文中的一个公式下标和表格单元格很模糊，请翻译其余内容。",
      "expected_output": "对无法确认的区域使用明确标记，而不是根据上下文补写。",
      "files": [],
      "assertions": [
        {
          "text": "使用不确定性标记",
          "type": "content_contains",
          "pattern": "待核对|无法可靠辨认|原文模糊"
        }
      ]
    }
  ]
}
